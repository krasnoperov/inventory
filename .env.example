CLOUDFLARE_AI_ACCOUNT_ID=
CLOUDFLARE_AI_API_TOKEN=

# OpenAI API Configuration
OPENAI_API_KEY=

# Website-controlled audio generation.
# The provider is chosen automatically: ElevenLabs in production, the fake
# provider everywhere else. Set INVENTORY_AUDIO_PROVIDER only to override (e.g.
# to exercise real ElevenLabs audio locally). Only ELEVENLABS_API_KEY is needed
# for real audio — voices are selected per generation in the Forge Tray UI / CLI
# (loaded from the account's ElevenLabs voice library); there is no default voice.
# INVENTORY_AUDIO_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=
ELEVENLABS_AUDIO_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_MUSIC_MODEL_ID=music_v1
ELEVENLABS_SOUND_EFFECT_MODEL_ID=eleven_text_to_sound_v2
ELEVENLABS_MUSIC_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_SOUND_EFFECT_OUTPUT_FORMAT=mp3_44100_128

# Optional Lyria music provider. Users can select Lyria per music request while
# ElevenLabs remains the default music path.
LYRIA_PROJECT_ID=
LYRIA_LOCATION=global
LYRIA_MODEL_ID=lyria-3-clip-preview
LYRIA_ACCESS_TOKEN=
LYRIA_API_KEY=
LYRIA_BASE_URL=

# Optional: AI Gateway for caching and analytics
AI_GATEWAY_URL=

# Experimental rotation generation surface. Leave unset/false in production
# until rotation quality is good enough to offer broadly.
MAKEFX_ROTATION_ENABLED=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OIDC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
OIDC_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
OIDC_KEY_ID=primary
# For local dev: http://localhost:3001
# For production: https://inventory.krasnoperov.me
OIDC_ISSUER=http://localhost:3001
OIDC_AUDIENCE=forgetray-api
OIDC_ALLOWED_CLIENT_IDS=["forgetray-cli"]

# Polar.sh Billing (use sandbox for local development)
# Get tokens from: https://sandbox.polar.sh (sandbox) or https://polar.sh (production)
POLAR_ACCESS_TOKEN=polar_at_sandbox_xxx
POLAR_ORGANIZATION_ID=org_xxx
POLAR_PAID_GENERATION_PRODUCT_ID=prod_xxx
POLAR_ENVIRONMENT=sandbox
POLAR_WEBHOOK_SECRET=whsec_xxx

# Internal API authentication (for cron jobs, internal billing sync)
INTERNAL_API_SECRET=your-internal-secret
