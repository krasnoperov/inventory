{
  "name": "inventory",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "inventory": "./dist/cli/inventory.mjs"
  },
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "bootstrap:worktree": "node ./scripts/bootstrap-worktree.mjs",
    "dev": "vite",
    "build": "vite build && pnpm run build:frontend-ssr && pnpm run build:cli",
    "build:frontend-ssr": "vite build --ssr ssr.tsx --outDir ../../dist/frontend-ssr --emptyOutDir",
    "build:cli": "node scripts/build-cli.mjs",
    "deploy": "pnpm run build && pnpm exec wrangler deploy",
    "deploy:production": "pnpm run build && pnpm exec wrangler deploy --env production",
    "deploy:stage": "pnpm run build && pnpm exec wrangler deploy",
    "test": "node ./scripts/run-node-tests.mjs",
    "test:components": "playwright test --config playwright.component.config.ts",
    "test:components:ci": "node ./scripts/run-component-ci.mjs",
    "test:e2e:media-foundation": "pnpm run build && node scripts/e2e-media-foundation.mjs",
    "test:e2e:cli-forge": "pnpm run build:cli && node scripts/e2e-cli-forge.mjs",
    "lint": "oxlint --config .oxlintrc.json src scripts && pnpm d1:guard",
    "d1:guard": "node scripts/check-no-d1-transactions.mjs",
    "typecheck": "tsc --noEmit",
    "ci:pre-push": "pnpm run typecheck && pnpm run lint && pnpm run build && pnpm test --test-reporter=dot && pnpm run test:components:ci",
    "db:migrate": "node --import @swc-node/register/esm-register scripts/db-migrate.ts",
    "db:migrate:stage": "node --import @swc-node/register/esm-register scripts/db-migrate.ts stage remote",
    "db:migrate:production": "node --import @swc-node/register/esm-register scripts/db-migrate.ts production remote",
    "cli": "node dist/cli/inventory.mjs",
    "cli:dev": "node --import @swc-node/register/esm-register src/cli/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "@google/genai": "^1.30.0",
    "@hono/zod-openapi": "^1.4.0",
    "@openai/agents": "^0.3.3",
    "@polar-sh/sdk": "^0.41.5",
    "@react-oauth/google": "^0.12.2",
    "@tanstack/react-query": "^5.90.11",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "@types/d3-force": "^3.0.10",
    "@types/dagre": "^0.7.53",
    "@xyflow/react": "^12.9.3",
    "better-sqlite3": "^12.4.6",
    "d3-force": "^3.0.0",
    "dagre": "^0.8.5",
    "dotenv": "^17.2.3",
    "fflate": "^0.8.2",
    "hono": "^4.10.6",
    "inversify": "^7.10.4",
    "jose": "^6.1.2",
    "kysely": "^0.28.8",
    "kysely-d1": "^0.4.0",
    "nanoid": "^5.1.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "remark-gfm": "^4.0.1",
    "uuid": "^13.0.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@cloudflare/ai": "^1.2.2",
    "@cloudflare/vite-plugin": "^1.39.0",
    "@cloudflare/workers-types": "4.20260317.1",
    "@csstools/postcss-light-dark-function": "^3.0.0",
    "@playwright/test": "^1.59.1",
    "@swc-node/register": "^1.11.1",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "express": "^5.1.0",
    "oxlint": "1.67.0",
    "postcss": "^8.5.6",
    "postcss-preset-env": "^10.4.0",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "wrangler": "4.95.0"
  }
}
